<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_bg"
    android:keepScreenOn="true"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvLiftType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SQUAT"
        android:textColor="@color/primary_red"
        android:textSize="38sp"
        android:textStyle="bold"
        android:letterSpacing="0.03"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

    <LinearLayout
        android:id="@+id/llTargetReps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvLiftType"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/tvTarget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Target: 90°"
            android:textColor="@color/accent_red"
            android:textSize="16sp"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:id="@+id/tvRepsCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reps: 0"
            android:textColor="@color/primary_red"
            android:textSize="18sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- HUD CIRCLE - PIÙ IN ALTO -->
    <ProgressBar
        android:id="@+id/progressBarDepth"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:indeterminate="false"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@drawable/circular_progress"
        android:rotation="-90"
        app:layout_constraintTop_toBottomOf="@id/llTargetReps"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp"/>

    <TextView
        android:id="@+id/tvAngle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0°"
        android:textColor="@color/text_primary"
        android:textSize="72sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/progressBarDepth"
        app:layout_constraintEnd_toEndOf="@id/progressBarDepth"
        app:layout_constraintStart_toStartOf="@id/progressBarDepth"
        app:layout_constraintTop_toTopOf="@id/progressBarDepth" />

    <TextView
        android:id="@+id/tvCountdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/accent_yellow"
        android:textSize="48sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/progressBarDepth"
        app:layout_constraintEnd_toEndOf="@id/progressBarDepth"
        app:layout_constraintStart_toStartOf="@id/progressBarDepth"
        app:layout_constraintTop_toTopOf="@id/progressBarDepth" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/press_start"
        android:textColor="@color/text_secondary"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/progressBarDepth"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp" />

    <TextView
        android:id="@+id/tvInstructions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Istruzioni..."
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/tvSignature"
        android:text="by ff9"
        android:textSize="11sp"
        android:textColor="@color/text_secondary"
        android:textStyle="italic"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@id/llButtons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <LinearLayout
        android:id="@+id/llButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="20dp"
        android:layout_marginHorizontal="16dp">

        <Button
            android:id="@+id/btnStart"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="64dp"
            android:text="@string/start"
            android:backgroundTint="@color/primary_red"
            android:textColor="@color/text_light"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"
            app:cornerRadius="16dp"/>

        <Button
            android:id="@+id/btnFinish"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="64dp"
            android:text="@string/finish"
            android:backgroundTint="@color/text_secondary"
            android:textColor="@color/text_light"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="gone"
            android:layout_marginStart="8dp"
            app:cornerRadius="16dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
